<!-- Astroid icon from Lucide -->

<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-astroid-icon lucide-astroid" id="theAstroid">
  <path id="star" d="M12.983 21.186a1 1 0 0 1-1.966 0 10 10 0 0 0-8.203-8.203 1 1 0 0 1 0-1.966 10 10 0 0 0 8.203-8.203 1 1 0 0 1 1.966 0 10 10 0 0 0 8.203 8.203 1 1 0 0 1 0 1.966 10 10 0 0 0-8.203 8.203"/>
</svg>

<!-- GSAP Scripting -->
<script type="module">
    import { addIconToTimeline } from "/sharedTimeline.js";

    addIconToTimeline((tl) => {
        tl.set('.lucide-astroid', {autoAlpha: 0});
        tl.fromTo('.lucide-astroid', {autoAlpha: 0}, {autoAlpha: 1, duration: 0.5});
        tl.fromTo('#star', { opacity: 0 }, { opacity: 1, yoyo: true, repeat: 4, duration: .5 });
        tl.to('#star', {transformOrigin: 'center center', scale: 250, duration: 1});
        tl.fromTo('.lucide-astroid', {autoAlpha: 1}, {autoAlpha: 0, duration: 0.5});
    });
</script>
