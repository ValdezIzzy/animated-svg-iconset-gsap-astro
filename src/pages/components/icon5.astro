<!-- Orbit icon from Lucide -->

<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-orbit-icon lucide-orbit" id="theOrbit">
  
  <g class="spiral">
  <g id="spiral-1">
  <path d="M20.341 6.484A10 10 0 0 1 10.266 21.85"/>
  <circle cx="19" cy="5" r="2"/>
  </g>
  
  <g id="spiral-2">
  <path d="M3.659 17.516A10 10 0 0 1 13.74 2.152"/>
  <circle cx="5" cy="19" r="2"/>
  </g>
  
  </g>  
    
  <circle cx="12" cy="12" r="3"/>
  
</svg>

<!-- GSAP Scripting -->
<script type="module">
    import { addIconToTimeline } from "/sharedTimeline.js";

    addIconToTimeline((tl) => {
        tl.set('.lucide-orbit', {autoAlpha: 0});
        tl.fromTo('.lucide-orbit', {autoAlpha: 0}, {autoAlpha: 1, duration: 0.5});
        tl.to('.spiral', {transformOrigin: 'center center', rotate: 360, duration: 3});
        tl.from('#spiral-1', {opacity: 0, x: 50, duration: 2}, '<');
        tl.from('#spiral-2', {opacity: 0, x: -50, duration: 2}, '<');
        tl.to('#spiral-1, #spiral-2', {opacity: 1}, '<');
        tl.fromTo('.lucide-orbit', {autoAlpha: 1}, {autoAlpha: 0, duration: 0.5});
    });
</script>
